{
  "manifest_version": 3,
  "name": "LinguaStream - Video Translator",
  "short_name": "LinguaStream",
  "description": "Prepares YouTube and Bilibili video transcripts locally, translates English speech to Simplified Chinese, and speaks it in sync with playback.",
  "version": "0.3.4",
  "icons": {
    "16": "assets/icons/linguastream-icon-16.png",
    "32": "assets/icons/linguastream-icon-32.png",
    "48": "assets/icons/linguastream-icon-48.png",
    "128": "assets/icons/linguastream-icon-128.png"
  },
  "action": {
    "default_title": "LinguaStream",
    "default_icon": {
      "16": "assets/icons/linguastream-icon-16.png",
      "32": "assets/icons/linguastream-icon-32.png",
      "48": "assets/icons/linguastream-icon-48.png",
      "128": "assets/icons/linguastream-icon-128.png"
    },
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*",
    "https://www.bilibili.com/*",
    "https://m.bilibili.com/*",
    "https://b23.tv/*",
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*",
        "https://www.bilibili.com/*",
        "https://m.bilibili.com/*",
        "https://b23.tv/*"
      ],
      "js": [
        "config/runtime.js",
        "content/namespace.js",
        "content/control-button.js",
        "content/content-script.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/icons/deepseek-icon-32.png",
        "assets/icons/google-icon-32.png",
        "assets/icons/volcengine-icon-32.png"
      ],
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*",
        "https://www.bilibili.com/*",
        "https://m.bilibili.com/*",
        "https://b23.tv/*"
      ]
    }
  ]
}
